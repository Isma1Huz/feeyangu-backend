APP_NAME=FeeYangu
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Africa/Nairobi
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=feeyangu
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_DRIVER=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@feeyangu.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=

VITE_APP_NAME="${APP_NAME}"

# ─── Authentication ──────────────────────────────────────────────────────────────
FORTIFY_USERNAME=email
FORTIFY_HOME=/dashboard

# ─── Africa's Talking (SMS/OTP) ──────────────────────────────────────────────────
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=
AFRICASTALKING_SENDER_ID=FeeYangu

# ─── Stripe (SaaS Billing) ───────────────────────────────────────────────────────
STRIPE_KEY=pk_test_
STRIPE_SECRET=sk_test_
STRIPE_WEBHOOK_SECRET=whsec_

CASHIER_CURRENCY=kes
CASHIER_CURRENCY_LOCALE=sw_KE

# ─── Subscription Plan Stripe Price IDs ──────────────────────────────────────────
STRIPE_PRICE_STARTER_MONTHLY=price_
STRIPE_PRICE_STARTER_ANNUAL=price_
STRIPE_PRICE_GROWTH_MONTHLY=price_
STRIPE_PRICE_GROWTH_ANNUAL=price_
STRIPE_PRICE_PRO_MONTHLY=price_
STRIPE_PRICE_PRO_ANNUAL=price_

# ─── M-Pesa (Safaricom Daraja API) ───────────────────────────────────────────────
MPESA_ENVIRONMENT=sandbox
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PASSKEY=
MPESA_SHORTCODE=
MPESA_CALLBACK_URL="${APP_URL}/api/payments/callback/mpesa"
MPESA_VALIDATION_URL="${APP_URL}/api/payments/mpesa/validate"
MPESA_CONFIRMATION_URL="${APP_URL}/api/payments/mpesa/confirm"

# ─── KCB Bank ────────────────────────────────────────────────────────────────────
KCB_ENVIRONMENT=sandbox
KCB_CLIENT_ID=
KCB_CLIENT_SECRET=
KCB_API_KEY=

# ─── Equity Bank (Jenga API) ─────────────────────────────────────────────────────
JENGA_ENVIRONMENT=sandbox
JENGA_MERCHANT_CODE=
JENGA_CONSUMER_SECRET=
JENGA_API_KEY=
JENGA_PRIVATE_KEY=

# ─── NCBA Bank (Loop API) ────────────────────────────────────────────────────────
NCBA_ENVIRONMENT=sandbox
NCBA_CLIENT_ID=
NCBA_CLIENT_SECRET=

# ─── Co-operative Bank (Connect API) ─────────────────────────────────────────────
COOP_ENVIRONMENT=sandbox
COOP_CLIENT_ID=
COOP_CLIENT_SECRET=
COOP_ACCOUNT_NUMBER=

# ─── Absa Bank ───────────────────────────────────────────────────────────────────
ABSA_ENVIRONMENT=sandbox
ABSA_CLIENT_ID=
ABSA_CLIENT_SECRET=

# ─── Stanbic Bank ────────────────────────────────────────────────────────────────
STANBIC_ENVIRONMENT=sandbox
STANBIC_CLIENT_ID=
STANBIC_CLIENT_SECRET=

# ─── Diamond Trust Bank ───────────────────────────────────��──────────────────────
DTB_ENVIRONMENT=sandbox
DTB_CLIENT_ID=
DTB_CLIENT_SECRET=

# ─── I&M Bank ────────────────────────────────────────────────────────────────────
IM_BANK_ENVIRONMENT=sandbox
IM_BANK_CLIENT_ID=
IM_BANK_CLIENT_SECRET=

# ─── Family Bank ─────────────────────────────────────────────────────────────────
FAMILY_BANK_ENVIRONMENT=sandbox
FAMILY_BANK_CLIENT_ID=
FAMILY_BANK_CLIENT_SECRET=

# ─── Laravel Horizon ─────────────────────────────────────────────────────────────
HORIZON_ENVIRONMENTS=production,staging,local